.app {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f0f0f0;
}

/* header */
.header {
  background: #fff;
  padding: 12px 16px;
  border-bottom: 1px solid #eee;
  flex-shrink: 0;
}
.title { font-size: 18px; font-weight: 700; color: #ff6900; }
.subtitle { font-size: 11px; color: #999; margin-left: 6px; }

/* guide */
.guide-msg, .welcome-msg {
  text-align: center;
  padding: 80px 24px 40px;
}
.guide-icon { font-size: 44px; margin-bottom: 12px; }
.guide-title { font-size: 18px; font-weight: 600; display: block; margin-bottom: 6px; }
.guide-desc { font-size: 13px; color: #999; display: block; margin-bottom: 16px; }
.guide-tip {
  background: #fff3cd;
  border: 1px solid #ffc107;
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 12px;
  color: #856404;
  display: inline-block;
  margin-bottom: 20px;
}
.guide-btn {
  background: #ff6900;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
  padding: 10px 0;
}
.examples { display: flex; flex-direction: column; gap: 8px; }
.example-btn {
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 10px;
  font-size: 13px;
  text-align: left;
  padding: 10px 14px;
  color: #333;
  white-space: normal;
  line-height: 1.5;
}

/* chat area */
.chat-area {
  flex: 1;
  padding: 12px 14px;
  overflow-y: auto;
}

/* messages */
.msg-row {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  max-width: 88%;
  animation: fadeIn .3s;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}
.msg-user { align-self: flex-end; flex-direction: row-reverse; margin-left: auto; }
.msg-ai { align-self: flex-start; }

.avatar {
  width: 30px; height: 30px;
  border-radius: 50%;
  font-size: 12px; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.msg-user .avatar { background: #ff6900; color: #fff; }
.msg-ai .avatar { background: #fff; border: 1px solid #ddd; color: #666; }

.bubble {
  padding: 10px 13px;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.6;
  word-break: break-all;
}
.bubble-user {
  background: #ff6900; color: #fff;
  border-bottom-right-radius: 4px;
}
.bubble-ai {
  background: #fff; border: 1px solid #eee;
  border-bottom-left-radius: 4px;
}

.msg-image { max-width: 200px; border-radius: 8px; margin-bottom: 6px; }

/* typing */
.typing-dots { display: flex; gap: 4px; padding: 2px 0; }
.typing-dots view {
  width: 6px; height: 6px; border-radius: 50%; background: #ccc;
  animation: dot 1.4s infinite both;
}
.typing-dots view:nth-child(2) { animation-delay: .2s; }
.typing-dots view:nth-child(3) { animation-delay: .4s; }
@keyframes dot {
  0%,80%,100% { transform: scale(.6); opacity: .4; }
  40% { transform: scale(1); opacity: 1; }
}

/* input */
.input-area {
  background: #fff;
  padding: 8px 12px;
  border-top: 1px solid #eee;
  flex-shrink: 0;
}
.image-preview { position: relative; display: inline-block; margin-bottom: 6px; }
.image-preview image { width: 70px; height: 70px; border-radius: 8px; }
.remove-img {
  position: absolute; top: -5px; right: -5px;
  width: 18px; height: 18px; border-radius: 50%;
  background: #333; color: #fff; font-size: 10px;
  display: flex; align-items: center; justify-content: center;
}
.input-row {
  display: flex; gap: 8px; align-items: center;
}
.chat-input {
  flex: 1;
  padding: 10px 14px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 14px;
}
.input-btns { display: flex; gap: 6px; flex-shrink: 0; }
.btn-upload, .btn-send {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; padding: 0; border: none;
}
.btn-upload { background: #f0f0f0; }
.btn-send { background: #e0e0e0; color: #999; }
.btn-send--active { background: #ff6900; color: #fff; }
